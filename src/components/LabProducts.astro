---
import SectionHeading from './SectionHeading.astro';
import { labProductGroups, labProductsCopy } from '../content/labProducts';
import type { Locale } from '../content/site';

interface Props { lang: Locale; compact?: boolean }
const { lang, compact = false } = Astro.props;
const copy = labProductsCopy[lang];
const groups = labProductGroups[lang];
---

<section class:list={['lab-products', compact && 'lab-products--compact']}>
  <SectionHeading eyebrow={copy.eyebrow} title={copy.title} description={copy.description} />
  <div class="lab-product-grid">
    {groups.map((group, index) => (
      <article class="lab-product-card">
        <span class="card-index">0{index + 1}</span>
        <h3>{group.title}</h3>
        <p>{group.description}</p>
        <ul>
          {group.items.map((item) => (
            <li>
              <strong>{item.name}</strong>
              {item.note && <small>{item.note}</small>}
            </li>
          ))}
        </ul>
      </article>
    ))}
  </div>
  <p class="source-note">{copy.sourceNote}</p>
</section>
