---
interface Props { eyebrow?:string; title:string; description?:string; className?: string }
const {eyebrow,title,description,className}=Astro.props;
---
<div class:list={['section-heading', className]} data-reveal>{eyebrow && <span class="eyebrow">{eyebrow}</span>}<h2>{title}</h2>{description && <p>{description}</p>}</div>
