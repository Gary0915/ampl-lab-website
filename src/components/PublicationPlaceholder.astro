---
import PendingInformationCard from './PendingInformationCard.astro'; import { pending } from '../content/pending'; import type { Locale } from '../content/site'; interface Props {lang:Locale} const {lang}=Astro.props;
---
<div class="publication-shell" data-reveal><div class="publication-filter" aria-label="Publication filters"><span>{lang==='zh-Hant'?'全部年份':'All years'}</span><span>{lang==='zh-Hant'?'全部主題':'All topics'}</span><span>{lang==='zh-Hant'?'搜尋書目':'Search records'}</span></div><PendingInformationCard lang={lang} item={pending.publications}/></div>
