---
interface Props { eyebrow:string; title:string; description:string; secondary?:string; density?:'editorial'|'compact' }
const {eyebrow,title,description,secondary,density='compact'}=Astro.props;
---
<section class:list={['page-hero', `page-hero--${density}`]} data-hero-density={density} data-reveal><span class="eyebrow">{eyebrow}</span><h1>{title}</h1>{secondary && <p class="page-secondary">{secondary}</p>}<p>{description}</p></section>
