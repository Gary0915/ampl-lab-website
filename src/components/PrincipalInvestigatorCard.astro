---
import { lab, type Locale } from '../content/site';

interface Props { lang: Locale }
const { lang } = Astro.props;
const zh = lang === 'zh-Hant';
---

<article class="pi-card" data-reveal>
  <div class="pi-monogram" aria-hidden="true">SS</div>
  <div>
    <span class="eyebrow">{zh ? '主持教授' : 'Principal Investigator'}</span>
    <h2>{lab.professor[lang]}</h2>
    <p class="pi-affiliation">{lab.department[lang]}</p>
    <p>{zh ? '研究聚焦綠色合成、循環經濟、奈米與生物高分子複合材料、表面工程、摩擦學，以及模擬輔助的材料與製程設計。' : 'Research interests include green synthesis, circular economy, nano and biopolymer composites, surface engineering, tribology, and simulation-assisted materials and process design.'}</p>
    <a href={`mailto:${lab.email}`}>{lab.email}</a>
  </div>
</article>
