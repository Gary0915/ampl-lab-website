---
interface Props { title:string; description:string; motif:string; index:number } const {title,description,motif,index}=Astro.props;
---
<article class={`facility-card motif-${motif}`} data-reveal><span>0{index+1}</span><div class="facility-motif" aria-hidden="true"></div><h3>{title}</h3><p>{description}</p><small>Information pending verification</small></article>
