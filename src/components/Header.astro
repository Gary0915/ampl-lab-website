---
import { labels, routes, type Locale } from '../content'; interface Props { lang: Locale } const {lang}=Astro.props; const prefix=lang==='en'?'/en':''; const switchTo=lang==='en'?'繁中':'EN'; const switchHref=lang==='en'?'/':'/en/';
---
<header data-header><div class="nav-shell"><a class="brand" href={prefix+'/' } aria-label="AMPL home"><span>AMPL</span><small>Advanced Material<br/>and Processing Lab</small></a><nav class="desktop-nav" aria-label="Primary navigation">{routes.map(route=><a href={`${prefix}/${route}`}>{labels[lang][route]}</a>)}</nav><div class="nav-actions"><a class="locale" href={switchHref}>{switchTo}</a><a class="contact-link" href={`${prefix}/contact`}>{labels[lang].contact}</a><button data-menu-toggle aria-label="Open navigation" aria-controls="mobile-navigation" aria-expanded="false"><i></i><i></i></button></div></div><nav id="mobile-navigation" data-menu aria-label="Mobile navigation"><a href={prefix+'/'}>{labels[lang].home}</a>{routes.map(route=><a href={`${prefix}/${route}`}>{labels[lang][route]}</a>)}<a class="locale" href={switchHref}>{switchTo}</a></nav></header>
