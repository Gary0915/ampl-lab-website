---
import { labels, primaryRoutes, type Locale, type Route } from '../content/site';
import { getAlternateLocalePath, getLocalizedPath, getRouteFromPath } from '../utils/localizedRoutes';

interface Props {
  lang: Locale;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const currentRoute = getRouteFromPath(currentPath);
const targetLang: Locale = lang === 'en' ? 'zh-Hant' : 'en';
const switchTo = lang === 'en' ? '繁中' : 'EN';
const switchHref = getAlternateLocalePath(currentPath, targetLang);
const pathFor = (route: 'home' | Route) => getLocalizedPath(route, lang);
const isCurrent = (route: 'home' | Route) => currentRoute === route;
---

<header data-header>
  <div class="nav-shell">
    <a class="brand" href={pathFor('home')} aria-label="AMPL home">
      <span>AMPL</span><small>Advanced Material<br />and Processing Lab</small>
    </a>
    <nav class="desktop-nav" data-desktop-nav aria-label="Primary navigation">
      {primaryRoutes.map((route) => (
        <a
          href={pathFor(route)}
          data-nav-item={route}
          aria-current={isCurrent(route) ? 'page' : undefined}
        >{labels[lang][route]}</a>
      ))}
    </nav>
    <div class="nav-actions">
      <a class="locale" data-locale-switch href={switchHref}>{switchTo}</a>
      <a
        class="contact-link"
        data-contact-cta
        href={pathFor('contact')}
        aria-current={isCurrent('contact') ? 'page' : undefined}
      >{labels[lang].contact}</a>
      <button data-menu-toggle aria-label="Open navigation" aria-controls="mobile-navigation" aria-expanded="false"><i></i><i></i></button>
    </div>
  </div>
  <nav id="mobile-navigation" data-menu aria-label="Mobile navigation">
    <a href={pathFor('home')} data-mobile-nav-item="home" aria-current={isCurrent('home') ? 'page' : undefined}>{labels[lang].home}</a>
    {primaryRoutes.map((route) => (
      <a href={pathFor(route)} data-mobile-nav-item={route} aria-current={isCurrent(route) ? 'page' : undefined}>{labels[lang][route]}</a>
    ))}
    <a href={pathFor('contact')} data-mobile-nav-item="contact" aria-current={isCurrent('contact') ? 'page' : undefined}>{labels[lang].contact}</a>
    <a class="locale" data-locale-switch href={switchHref}>{switchTo}</a>
  </nav>
</header>
