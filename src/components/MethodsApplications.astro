---
import { methodsApplications } from '../content/research';
import type { Locale } from '../content/site';

interface Props { lang: Locale }
const { lang } = Astro.props;
const zh = lang === 'zh-Hant';
---

<div class="methods-applications">
  {methodsApplications[lang].map((item, index) => (
    <article class="methods-row">
      <span class="card-index">0{index + 1}</span>
      <div>
        <h3>{item.method}</h3>
        <p>{item.scope}</p>
      </div>
      <div class="application-list">
        <span>{zh ? '應用面向' : 'Applications'}</span>
        <ul>{item.applications.map((application) => <li>{application}</li>)}</ul>
      </div>
    </article>
  ))}
</div>
