---
import BaseLayout from '../layouts/BaseLayout.astro'; import HeroLattice from '../components/HeroLattice.astro'; import ResearchCard from '../components/ResearchCard.astro'; import Pipeline from '../components/Pipeline.astro'; import SectionHeading from '../components/SectionHeading.astro'; import SelectedPublications from '../components/SelectedPublications.astro'; import {researchAreas} from '../content/research';
const lang='zh-Hant' as const;
---
<BaseLayout title="尖端材料及製程實驗室" lang={lang}><section class="hero"><div data-reveal><span class="eyebrow">NCKU Mechanical Engineering · AMPL</span><h1>尖端材料<br/>及製程實驗室</h1><p class="subhead">Advanced Material and Processing Lab</p><p>以農漁業副產物的資源化為起點，串連奈米與生質複合材料、表面工程、磨潤行為，以及模擬輔助的材料與製程最佳化。</p><div class="hero-actions"><a class="button primary" href="#research">探索研究領域</a><a class="button secondary" href="/join-us">加入我們</a></div></div><HeroLattice/></section><section class="identity"><div><h2>研究識別<br/>Research identity</h2><p>從稻稈與漁業副產物，到奈米、生質複材與功能表面；以表徵與模擬連結材料設計、製程判斷與多元應用。</p></div></section><section id="research"><SectionHeading eyebrow="Research areas" title="研究領域" description="以資源循環、材料結構、界面工程與模擬設計建立 AMPL 的研究脈絡。"/><div class="research-grid">{researchAreas.map((area,index)=><ResearchCard title={area.title[lang]} description={area.description[lang]} tags={area.tags[lang]} motif={area.motif} {index}/>)}</div></section><section><SectionHeading eyebrow="Research pathway" title="材料至應用" description="從農漁業副產物的資源化，到功能材料與工程應用的研究流程。"/><Pipeline lang={lang}/></section><SelectedPublications lang={lang} variant="preview" /><section class="join"><div><div><span class="eyebrow">Join AMPL</span><h2>以材料研究，參與更具資源意識的未來。</h2><p>歡迎對材料製程、奈米材料、表面工程、摩擦學與模擬設計有興趣的研究夥伴。</p></div><a class="button primary" href="/join-us">了解加入方式</a></div></section></BaseLayout>
