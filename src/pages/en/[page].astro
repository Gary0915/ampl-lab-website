---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import PrincipalInvestigatorCard from '../../components/PrincipalInvestigatorCard.astro';
import ProfessorProfile from '../../components/ProfessorProfile.astro';
import MethodsApplications from '../../components/MethodsApplications.astro';
import ResearchCard from '../../components/ResearchCard.astro';
import ResearchCapabilitySummary from '../../components/ResearchCapabilitySummary.astro';
import Pipeline from '../../components/Pipeline.astro';
import OfficialProfileLinks from '../../components/OfficialProfileLinks.astro';
import SelectedPublications from '../../components/SelectedPublications.astro';
import PublicationExplorer from '../../components/PublicationExplorer.astro';
import FacilityEquipmentGroups from '../../components/FacilityEquipmentGroups.astro';
import LabProducts from '../../components/LabProducts.astro';
import ProjectCollaborationSummary from '../../components/ProjectCollaborationSummary.astro';
import { routes, editorialRoutes, type Route, labels, lab } from '../../content/site';
import { pageIntro, aboutCopy, joinCopy } from '../../content/pages';
import { researchAreas } from '../../content/research';
import { publicationCopy, recentJournalPublications } from '../../content/publications';
import { projectCopy } from '../../content/projects';

const lang = 'en' as const;
const page = Astro.params.page as Route;
if (!routes.includes(page)) return new Response(null, { status: 404 });
const intro = pageIntro[lang][page];
const about = aboutCopy[lang];
const join = joinCopy[lang];
const heroDensity = editorialRoutes.includes(page as (typeof editorialRoutes)[number]) ? 'editorial' : 'compact';

export function getStaticPaths() {
  return routes.map((page) => ({ params: { page } }));
}
---

<BaseLayout title={labels[lang][page]} lang={lang} route={page}>
  <PageHero eyebrow={`AMPL · ${labels[lang][page]}`} title={intro.title} description={intro.description} secondary={page === 'about' ? lab.chineseName : undefined} density={heroDensity} />

  <section class="page-content">
    {page === 'about' && <>
      <SectionHeading eyebrow="Lab profile" title="About the lab" description={about.profile} />
      <ProfessorProfile lang={lang} />
      <div class="prose-grid">
        <article><h2>Research philosophy</h2><p>{about.philosophy}</p></article>
        <article><h2>Lab mission</h2><p>{about.mission}</p></article>
      </div>
    </>}

    {page === 'research' && <>
      <SectionHeading eyebrow="Six connected areas" title="Materials research from resources to applications" description="Six research areas connect green synthesis, nanomaterials, biopolymer composites, surface engineering, tribology, functional materials, and simulation-assisted optimization." />
      <div class="research-grid">
        {researchAreas.map((area, index) => <ResearchCard title={area.title[lang]} description={area.description[lang]} tags={area.tags[lang]} motif={area.motif} {index} />)}
      </div>
      <SectionHeading eyebrow="Research capability summary" title="Research capability framework" description="Six capability areas organize the AMPL material research rhythm and connect the themes with methods and applications." />
      <ResearchCapabilitySummary lang={lang} />
      <SectionHeading eyebrow="AMPL pathway" title="Research pathway" description="From agricultural and fishery by-products to material design, processing, characterization, simulation, and application contexts." />
      <Pipeline lang={lang} />
      <SectionHeading eyebrow="Methods × applications" title="Methods and application contexts" description="Material, surface, and simulation methods are organized alongside biomedical, environmental, sensing, and engineering application contexts." />
      <MethodsApplications lang={lang} />
    </>}

    {page === 'projects' && <>
      <ProjectCollaborationSummary lang={lang} />
      <div class="contact-callout project-contact-cta">
        <h2>{projectCopy[lang].ctaTitle}</h2>
        <p>{projectCopy[lang].ctaDescription}</p>
        <a class="button primary" href="/en/contact">{projectCopy[lang].ctaLabel}</a>
      </div>
    </>}

    {page === 'members' && <>
      <SectionHeading eyebrow="Principal investigator" title="Research team" description="This page presents publicly verified research team information." />
      <PrincipalInvestigatorCard lang={lang} />
    </>}

    {page === 'publications' && <>
      <SectionHeading eyebrow="Research records" title="Research publications" description="Selected publications and complete records will be presented with verified bibliographic information." />
      <OfficialProfileLinks lang={lang} />
      <SelectedPublications lang={lang} variant="full" />
      <PublicationExplorer lang={lang} publications={recentJournalPublications} />
      <p class="complete-records-note">{publicationCopy[lang].completeNote}</p>
    </>}

    {page === 'facilities' && <>
      <FacilityEquipmentGroups lang={lang} />
      <LabProducts lang={lang} />
    </>}

    {page === 'news' && <>
      <SectionHeading eyebrow="AMPL updates" title="Laboratory news" description="Laboratory announcements, research publications, and academic activities are published on this page." />
      <section class="public-empty-state" data-news-empty-state><span class="eyebrow">News</span><h2>No public updates at this time</h2><p>Laboratory announcements and research updates are published here.</p></section>
    </>}

    {page === 'join-us' && <>
      <SectionHeading eyebrow="Graduate research opportunities" title="Research with AMPL" description={join.lead} />
      <div class="join-detail">
        <article><h2>Who should apply</h2><ul>{join.audiences.map((item) => <li>{item}</li>)}</ul></article>
        <article><h2>Research topics</h2><ul>{join.topics.map((item) => <li>{item}</li>)}</ul></article>
        <article><h2>Skills you may develop</h2><ul>{join.skills.map((item) => <li>{item}</li>)}</ul></article>
      </div>
      <div class="contact-callout"><h2>How to contact</h2><p>{join.contact}</p><a class="button primary" href={`mailto:${lab.email}`}>{lab.email}</a></div>
    </>}

    {page === 'contact' && <>
      <SectionHeading eyebrow="Get in touch" title="Contact" description="Please contact Prof. Shih-Chen Shi for research exchange, collaboration, graduate study enquiries, or other academic communication." />
      <div class="contact-grid contact-grid--detailed">
        <article><span>Professor</span><h3>{lab.professor[lang]}</h3></article>
        <article><span>Department</span><h3>{lab.department[lang]}</h3></article>
        <article><span>Professor Office</span><h3>{lab.rooms.professorOffice[lang]}</h3></article>
        <article><span>Laboratory</span><h3>{lab.rooms.laboratory[lang]}</h3></article>
        <article><span>Student Discussion Room</span><h3>{lab.rooms.studentDiscussionRoom[lang]}</h3></article>
        <article><span>Telephone</span><h3>Professor Office {lab.phones.professorOffice}<br />Laboratory {lab.phones.laboratory}</h3></article>
        <article><span>Email</span><h3><a href={`mailto:${lab.email}`}>{lab.email}</a></h3></article>
        <article><span>Professor website</span><h3><a href={lab.personalWebsiteUrl} target="_blank" rel="noreferrer">ampl.me.ncku.edu.tw <span aria-hidden="true">↗</span></a></h3></article>
      </div>
      <a class="button primary external-map-link" href={lab.campusMapUrl} target="_blank" rel="noreferrer">Official NCKU campus map <span aria-hidden="true">↗</span></a>
    </>}
  </section>
</BaseLayout>
