---
import BaseLayout from '../../layouts/BaseLayout.astro'; import { routes, labels, pending, type Route } from '../../content'; const page=Astro.params.page as Route; if(!routes.includes(page)) return new Response(null,{status:404}); const intro:Record<Route,string>={about:'The academic identity and research direction of AMPL.',research:'Research themes at the intersection of materials and processes.',members:'Current laboratory membership will be published after confirmation.',publications:'Verified publication details will be published after confirmation.',facilities:'Facility details and photographs will be published after confirmation.',news:'Laboratory news will be published after confirmation.','join-us':'We welcome students interested in materials, processes, and sustainable engineering.',contact:'Contact AMPL for academic exchange and research collaboration.'};
export function getStaticPaths() { return routes.map((page) => ({ params: { page } })); }
---
<BaseLayout title={labels.en[page]} lang="en"><section class="page-hero"><span class="eyebrow">AMPL · {labels['zh-Hant'][page]}</span><h1>{labels.en[page]}</h1><p>{intro[page]}</p></section><section class="page-content">{page==='about'?<><h2>Advanced Material and Processing Lab</h2><p>AMPL is part of the Department of Mechanical Engineering at National Cheng Kung University and is led by Prof. Shih-Chen Shi.</p></>:page==='contact'?<><h2>Contact</h2><p><a href="mailto:scshi@mail.ncku.edu.tw">scshi@mail.ncku.edu.tw</a></p></>:page==='join-us'?<><h2>Explore research with AMPL</h2><p>Students interested in materials processing, nanomaterials, surface engineering, tribology, and simulation-assisted material design are welcome to get in touch.</p><a class="button primary" href="mailto:scshi@mail.ncku.edu.tw">Contact the professor</a></>:<div class="placeholder"><b>{labels.en[page].toUpperCase()}</b>{pending.en}</div>}</section></BaseLayout>
