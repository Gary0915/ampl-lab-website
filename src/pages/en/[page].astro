---
import BaseLayout from '../../layouts/BaseLayout.astro'; import PageHero from '../../components/PageHero.astro'; import SectionHeading from '../../components/SectionHeading.astro'; import PrincipalInvestigatorCard from '../../components/PrincipalInvestigatorCard.astro'; import PendingInformationCard from '../../components/PendingInformationCard.astro'; import PublicationPlaceholder from '../../components/PublicationPlaceholder.astro'; import FacilityCategoryCard from '../../components/FacilityCategoryCard.astro'; import NewsCategoryCard from '../../components/NewsCategoryCard.astro'; import ResearchCard from '../../components/ResearchCard.astro'; import Pipeline from '../../components/Pipeline.astro'; import {routes,type Route,labels,lab} from '../../content/site'; import {pageIntro,aboutCopy,joinCopy} from '../../content/pages'; import {pending} from '../../content/pending'; import {researchAreas} from '../../content/research'; import {facilityCategories} from '../../content/facilities'; import {newsCategories} from '../../content/news';
const lang='en' as const; const page=Astro.params.page as Route; if(!routes.includes(page)) return new Response(null,{status:404}); const intro=pageIntro[lang][page]; const about=aboutCopy[lang]; const join=joinCopy[lang];
export function getStaticPaths() { return routes.map((page) => ({ params: { page } })); }
---
<BaseLayout title={labels[lang][page]} lang={lang}><PageHero eyebrow={`AMPL · ${labels['zh-Hant'][page]}`} title={intro.title} description={intro.description} secondary={page==='about'?lab.chineseName:undefined}/><section class="page-content">
{page==='about' && <><SectionHeading eyebrow="Lab profile" title="About the lab" description={about.profile}/><PrincipalInvestigatorCard lang={lang}/><div class="prose-grid"><article><h2>Research philosophy</h2><p>{about.philosophy}</p></article><article><h2>Lab mission</h2><p>{about.mission}</p></article></div></>}
{page==='research' && <><SectionHeading eyebrow="Six connected areas" title="Materials research from resources to applications" description="Six research areas are connected by a shared materials and process logic."/><div class="research-grid">{researchAreas.map((area,index)=><ResearchCard title={area.title[lang]} description={area.description[lang]} tags={area.tags[lang]} motif={area.motif} {index}/>)}</div><SectionHeading eyebrow="AMPL pathway" title="Research pathway" description="Experiment and simulation jointly support material and process decisions."/><Pipeline lang={lang}/></>}
{page==='members' && <><SectionHeading eyebrow="Principal investigator" title="Principal Investigator" description="Research leadership and contact information are presented through verified records."/><PrincipalInvestigatorCard lang={lang}/><div class="pending-grid"><PendingInformationCard lang={lang} item={pending.members}/><PendingInformationCard lang={lang} item={pending.alumni}/></div></>}
{page==='publications' && <><SectionHeading eyebrow="Research records" title="Selected publications" description="Publication records will be formally updated using verified bibliographic information."/><PublicationPlaceholder lang={lang}/></>}
{page==='facilities' && <><SectionHeading eyebrow="Research capability categories" title="Facility categories" description="Capabilities are presented by research category; verified equipment details and photographs will follow."/><div class="facility-grid">{facilityCategories[lang].map((item,index)=><FacilityCategoryCard {...item} {index}/>)}</div><PendingInformationCard lang={lang} item={pending.facility}/></>}
{page==='news' && <><SectionHeading eyebrow="Formal updates" title="News categories" description="A formal surface for research and activity updates without invented content."/><div class="news-grid">{newsCategories[lang].map((item,index)=><NewsCategoryCard {...item} {index}/>)}</div><PendingInformationCard lang={lang} item={pending.news}/></>}
{page==='join-us' && <><SectionHeading eyebrow="Graduate research opportunities" title="Research with AMPL" description={join.lead}/><div class="join-detail"><article><h2>Who should apply</h2><ul>{join.audiences.map(item=><li>{item}</li>)}</ul></article><article><h2>Research topics</h2><ul>{join.topics.map(item=><li>{item}</li>)}</ul></article><article><h2>Skills you may develop</h2><ul>{join.skills.map(item=><li>{item}</li>)}</ul></article></div><div class="contact-callout"><h2>How to contact</h2><p>{join.contact}</p><a class="button primary" href={`mailto:${lab.email}`}>{lab.email}</a></div></>}
{page==='contact' && <><SectionHeading eyebrow="Get in touch" title="Contact" description="Please contact AMPL for research exchange, collaboration, or graduate study enquiries."/><div class="contact-grid"><article><span>Professor</span><h3>{lab.professor}</h3></article><article><span>Department</span><h3>{lab.department}</h3></article><article><span>Email</span><h3><a href={`mailto:${lab.email}`}>{lab.email}</a></h3></article><article><span>Laboratory</span><h3>Advanced Material and Processing Lab</h3></article></div><PendingInformationCard lang={lang} item={pending.location}/></>}
</section></BaseLayout>
