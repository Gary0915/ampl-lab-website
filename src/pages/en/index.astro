---
import BaseLayout from '../../layouts/BaseLayout.astro'; import HeroLattice from '../../components/HeroLattice.astro'; import ResearchCard from '../../components/ResearchCard.astro'; import Pipeline from '../../components/Pipeline.astro'; import SectionHeading from '../../components/SectionHeading.astro'; import SelectedPublications from '../../components/SelectedPublications.astro'; import {researchAreas} from '../../content/research';
const lang='en' as const;
---
<BaseLayout title="Advanced Material and Processing Lab" lang={lang} route="home"><section class="hero"><div data-reveal><span class="eyebrow">NCKU Mechanical Engineering · AMPL</span><h1>Advanced Material<br/>and Processing Lab</h1><p class="subhead">尖端材料及製程實驗室</p><p>Starting from the reuse of agricultural and fishery by-products, AMPL connects nano and biopolymer composites, surface engineering, tribology, and simulation-assisted material and process optimization.</p><div class="hero-actions"><a class="button primary" href="#research">Explore research</a><a class="button secondary" href="/en/join-us">Join us</a></div></div><HeroLattice/></section><section class="identity"><div><h2>Research identity</h2><p>From rice straw and fishery by-products to nanomaterials, biopolymer composites, and functional surfaces—connecting characterization and simulation with material design, process decisions, and applications.</p></div></section><section id="research"><SectionHeading eyebrow="Research areas" title="Research areas" description="AMPL brings together circular resources, material structures, interface engineering, and simulation-assisted design."/><div class="research-grid">{researchAreas.map((area,index)=><ResearchCard title={area.title[lang]} description={area.description[lang]} tags={area.tags[lang]} motif={area.motif} {index}/>)}</div></section><section><SectionHeading eyebrow="Research pathway" title="Materials to applications" description="A research path from agricultural and fishery by-products to functional materials and engineering applications."/><Pipeline lang={lang}/></section><SelectedPublications lang={lang} variant="preview" /><section class="join"><div><div><span class="eyebrow">Join AMPL</span><h2>Study materials for a more resource-aware future.</h2><p>We welcome prospective researchers interested in materials processing, nanomaterials, surface engineering, tribology, and simulation-assisted design.</p></div><a class="button primary" href="/en/join-us">Learn how to join</a></div></section></BaseLayout>
