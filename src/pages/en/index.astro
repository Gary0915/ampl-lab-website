---
import BaseLayout from '../../layouts/BaseLayout.astro'; import HeroLattice from '../../components/HeroLattice.astro'; import ResearchCard from '../../components/ResearchCard.astro'; import Pipeline from '../../components/Pipeline.astro'; import {research,pending} from '../../content';
---
<BaseLayout title="Advanced Material and Processing Lab" lang="en"><section class="hero"><div data-reveal><span class="eyebrow">NCKU Mechanical Engineering · AMPL</span><h1>Advanced Material<br/>and Processing Lab</h1><p class="subhead">尖端材料及製程實驗室</p><p>Research at the intersection of green synthesis, circular economy, nanomaterials, and surface engineering.</p><div class="hero-actions"><a class="button primary" href="#research">Explore research</a><a class="button secondary" href="/en/join-us">Join us</a></div></div><HeroLattice/></section><section class="identity"><div><h2>Research identity</h2><p>From sustainable resources to functional materials, connecting material structure, processing, characterization, and applications.</p></div></section><section id="research"><div class="section-head"><h2>Research areas</h2><p>Materials thinking across circularity, interfaces, processing, and simulation-assisted optimization.</p></div><div class="research-grid">{research.map(([english,chinese,description],index)=><ResearchCard {english} {chinese} {description} {index}/>)}</div></section><section><div class="section-head"><h2>Materials to applications</h2><p>A research path from resources to material performance and practical use.</p></div><Pipeline/></section><section><div class="placeholder"><b>SELECTED HIGHLIGHTS</b>{pending.en}</div></section></BaseLayout>
