---
import BaseLayout from '../layouts/BaseLayout.astro'; import { routes, labels, pending, research, type Route } from '../content'; const page=Astro.params.page as Route; if(!routes.includes(page)) return new Response(null,{status:404}); const descriptions:Record<Route,string>={about:'認識 AMPL 的研究定位、學術脈絡與團隊精神。',research:'以材料科學與製程工程為基礎，探索永續與高效能材料。',members:'實驗室成員資訊將在確認後更新。',publications:'研究成果與完整書目將以確認資料為準。',facilities:'設備類別與影像資料將在確認後更新。',news:'實驗室近期消息將在確認後發布。','join-us':'我們歡迎對材料、製程與永續工程有好奇心的研究夥伴。',contact:'聯繫 AMPL，開啟學術交流與研究合作。'};
export function getStaticPaths() { return routes.map((page) => ({ params: { page } })); }
---
<BaseLayout title={labels['zh-Hant'][page]} lang="zh-Hant"><section class="page-hero"><span class="eyebrow">AMPL · {labels.en[page]}</span><h1>{labels['zh-Hant'][page]}</h1><p>{descriptions[page]}</p></section><section class="page-content">{page==='research'?<div class="research-grid">{research.map(([english,chinese,description],index)=><article class="research-card"><div class="card-index">0{index+1}</div><h3>{chinese}</h3><p class="english-title">{english}</p><p>{description}</p></article>)}</div>:page==='about'?<><h2>Advanced Material and Processing Lab</h2><p>尖端材料及製程實驗室隸屬國立成功大學機械工程學系，由 Prof. Shih-Chen Shi 帶領，聚焦先進材料與製程研究。</p><div class="placeholder"><b>LAB PROFILE</b>{pending['zh-Hant']}</div></>:page==='contact'?<><h2>聯絡資訊</h2><p>Prof. Shih-Chen Shi<br/><a href="mailto:scshi@mail.ncku.edu.tw">scshi@mail.ncku.edu.tw</a></p><div class="placeholder"><b>LOCATION</b>{pending['zh-Hant']}</div></>:page==='join-us'?<><h2>一起研究材料的下一步</h2><p>歡迎對材料製程、奈米材料、表面工程、摩擦學、生醫與環境材料，以及模擬輔助設計感興趣的學生。</p><a class="button primary" href="mailto:scshi@mail.ncku.edu.tw">聯絡教授</a></>:page==='publications'?<div class="publication"><b>[待確認]</b><div><h3>代表論文與完整書目</h3><p>{pending['zh-Hant']}</p></div></div>:<div class="placeholder"><b>{labels.en[page].toUpperCase()}</b>{pending['zh-Hant']}</div>}</section></BaseLayout>
