---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PrincipalInvestigatorCard from '../components/PrincipalInvestigatorCard.astro';
import ProfessorProfile from '../components/ProfessorProfile.astro';
import MethodsApplications from '../components/MethodsApplications.astro';
import ResearchCard from '../components/ResearchCard.astro';
import ResearchCapabilitySummary from '../components/ResearchCapabilitySummary.astro';
import Pipeline from '../components/Pipeline.astro';
import OfficialProfileLinks from '../components/OfficialProfileLinks.astro';
import SelectedPublications from '../components/SelectedPublications.astro';
import PublicationExplorer from '../components/PublicationExplorer.astro';
import FacilityEquipmentGroups from '../components/FacilityEquipmentGroups.astro';
import LabProducts from '../components/LabProducts.astro';
import ProjectCollaborationSummary from '../components/ProjectCollaborationSummary.astro';
import { routes, editorialRoutes, type Route, labels, lab } from '../content/site';
import { pageIntro, aboutCopy, joinCopy } from '../content/pages';
import { researchAreas } from '../content/research';
import { publicationCopy, recentJournalPublications } from '../content/publications';
import { projectCopy } from '../content/projects';

const lang = 'zh-Hant' as const;
const page = Astro.params.page as Route;
if (!routes.includes(page)) return new Response(null, { status: 404 });
const intro = pageIntro[lang][page];
const about = aboutCopy[lang];
const join = joinCopy[lang];
const heroDensity = editorialRoutes.includes(page as (typeof editorialRoutes)[number]) ? 'editorial' : 'compact';

export function getStaticPaths() {
  return routes.map((page) => ({ params: { page } }));
}
---

<BaseLayout title={labels[lang][page]} lang={lang} route={page}>
  <PageHero eyebrow={`AMPL · ${labels.en[page]}`} title={intro.title} description={intro.description} secondary={page === 'about' ? lab.englishName : undefined} density={heroDensity} />

  <section class="page-content">
    {page === 'about' && <>
      <SectionHeading eyebrow="Lab profile" title="實驗室簡介" description={about.profile} />
      <ProfessorProfile lang={lang} />
      <div class="prose-grid">
        <article><h2>研究理念</h2><p>{about.philosophy}</p></article>
        <article><h2>研究使命</h2><p>{about.mission}</p></article>
      </div>
    </>}

    {page === 'research' && <>
      <SectionHeading className="section-heading--research-lead" eyebrow="Six connected areas" title="從材料來源到應用場域的六項研究主軸" description="以綠色合成、奈米與生質複合材料、表面工程、磨潤、功能材料與模擬最佳化，連結材料設計與應用需求。" />
      <div class="research-grid">
        {researchAreas.map((area, index) => <ResearchCard title={area.title[lang]} description={area.description[lang]} tags={area.tags[lang]} motif={area.motif} {index} />)}
      </div>
      <SectionHeading eyebrow="Research capability summary" title="研究能力架構" description="以六個能力面向整理 AMPL 的材料研究節奏，讓研究主軸與方法流程保持清楚對應。" />
      <ResearchCapabilitySummary lang={lang} />
      <SectionHeading eyebrow="AMPL pathway" title="研究流程" description="從農漁業副產物與材料設計出發，逐步連結製程、表面工程、表徵與模擬，再回到具體應用。" />
      <Pipeline lang={lang} />
      <SectionHeading eyebrow="Methods × applications" title="研究方法與應用面向" description="以材料、表面與模擬方法對應生醫、環境、感測及工程情境，支持材料與製程設計的整合判斷。" />
      <MethodsApplications lang={lang} />
    </>}

    {page === 'projects' && <>
      <ProjectCollaborationSummary lang={lang} />
      <div class="contact-callout project-contact-cta">
        <h2>{projectCopy[lang].ctaTitle}</h2>
        <p>{projectCopy[lang].ctaDescription}</p>
        <a class="button primary" href="/contact">{projectCopy[lang].ctaLabel}</a>
      </div>
    </>}

    {page === 'members' && <>
      <SectionHeading eyebrow="Principal investigator" title="研究團隊" description="本頁呈現已公開確認之研究團隊資訊。" />
      <PrincipalInvestigatorCard lang={lang} />
    </>}

    {page === 'publications' && <>
      <SectionHeading eyebrow="Research records" title="研究出版紀錄" description="精選論文與完整書目將以可核實的出版資訊整理呈現。" />
      <OfficialProfileLinks lang={lang} />
      <SelectedPublications lang={lang} variant="full" />
      <PublicationExplorer lang={lang} publications={recentJournalPublications} />
      <p class="complete-records-note">{publicationCopy[lang].completeNote}</p>
    </>}

    {page === 'facilities' && <>
      <FacilityEquipmentGroups lang={lang} />
      <LabProducts lang={lang} />
    </>}

    {page === 'news' && <>
      <SectionHeading eyebrow="AMPL updates" title="實驗室消息" description="實驗室公告、研究出版與學術活動統一刊載於此頁。" />
      <section class="public-empty-state" data-news-empty-state><span class="eyebrow">News</span><h2>目前尚無公開消息</h2><p>最新實驗室公告與研究消息將統一刊載於此頁。</p></section>
    </>}

    {page === 'join-us' && <>
      <SectionHeading eyebrow="Graduate research opportunities" title="加入 AMPL" description={join.lead} />
      <div class="join-detail">
        <article><h2>我們歡迎的背景</h2><ul>{join.audiences.map((item) => <li>{item}</li>)}</ul></article>
        <article><h2>研究主題</h2><ul>{join.topics.map((item) => <li>{item}</li>)}</ul></article>
        <article><h2>期待的能力</h2><ul>{join.skills.map((item) => <li>{item}</li>)}</ul></article>
      </div>
      <div class="contact-callout"><h2>聯絡方式</h2><p>{join.contact}</p><a class="button primary" href={`mailto:${lab.email}`}>{lab.email}</a></div>
    </>}

    {page === 'contact' && <>
      <SectionHeading eyebrow="Get in touch" title="聯絡資訊" description="歡迎以電子郵件與施士塵教授聯繫研究合作、研究所申請或其他學術交流事宜。" />
      <div class="contact-grid contact-grid--detailed">
        <article><span>教授</span><h3>{lab.professor[lang]}</h3></article>
        <article><span>系所</span><h3>{lab.department[lang]}</h3></article>
        <article><span>教授室</span><h3>{lab.rooms.professorOffice[lang]}</h3></article>
        <article><span>實驗室</span><h3>{lab.rooms.laboratory[lang]}</h3></article>
        <article><span>學生討論室</span><h3>{lab.rooms.studentDiscussionRoom[lang]}</h3></article>
        <article><span>電話</span><h3>教授室 {lab.phones.professorOffice}<br />實驗室 {lab.phones.laboratory}</h3></article>
        <article><span>Email</span><h3><a href={`mailto:${lab.email}`}>{lab.email}</a></h3></article>
        <article><span>個人網站</span><h3><a href={lab.personalWebsiteUrl} target="_blank" rel="noreferrer">ampl.me.ncku.edu.tw <span aria-hidden="true">↗</span></a></h3></article>
      </div>
      <a class="button primary external-map-link" href={lab.campusMapUrl} target="_blank" rel="noreferrer">成大官方校園地圖 <span aria-hidden="true">↗</span></a>
    </>}
  </section>
</BaseLayout>
